<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Estatísticas - Loterias IA</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/style.css">
    
    <!-- Firebase SDK (OBRIGATÓRIO) -->
    <script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-auth-compat.js"></script>
    
    <!-- Supabase SDK -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    
    <style>
        .stats-container { max-width: 1400px; margin: 0 auto; padding: 20px; }
        .lottery-grid-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 15px; margin-bottom: 30px; }
        .lottery-card-stats { background: var(--bg-secondary); padding: 15px; border-radius: var(--radius); border: 2px solid var(--border); cursor: pointer; transition: all 0.3s; text-align: center; }
        .lottery-card-stats:hover { transform: translateY(-3px); box-shadow: 0 5px 15px rgba(0,0,0,0.2); }
        .lottery-card-stats.active { border-color: #38bdf8; background: var(--bg-card); }
        .stats-cards-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 20px; }
        .stats-card { background: var(--bg-card); border-radius: var(--radius); padding: 15px; border: 2px solid var(--border); }
        .stats-card h4 { font-size: 14px; color: var(--text-secondary); margin-bottom: 12px; padding-bottom: 8px; border-bottom: 2px solid var(--border); display: flex; align-items: center; gap: 8px; }
        .stats-list { max-height: 300px; overflow-y: auto; }
        .stats-item { display: flex; justify-content: space-between; padding: 6px 8px; border-bottom: 1px solid var(--border); font-size: 13px; }
        .stats-item .numero { font-weight: 600; color: #38bdf8; }
        .stats-item .numero-pro { font-weight: 600; color: #f59e0b; /* filter: blur(4px);  ← REMOVIDO */ cursor: pointer; }
        /*.stats-item .numero-pro { font-weight: 600; color: #f59e0b; filter: blur(4px); cursor: pointer; transition: filter 0.2s; }*/
        .stats-item .numero-pro:hover { filter: blur(2px); }
        .stats-item .quantidade { color: #f59e0b; }
        .stats-item:hover { background: rgba(56, 189, 248, 0.1); }
        .pro-badge-stats { display: inline-block; background: linear-gradient(135deg, #f59e0b, #eab308); color: #1e293b; font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 20px; margin-left: 8px; }
        .pro-overlay { background: rgba(0,0,0,0.7); border-radius: 8px; padding: 20px; text-align: center; margin: 20px 0; }
        .periodo-filtros { display: flex; flex-wrap: wrap; gap: 10px; margin: 15px 0; }
        .periodo-btn { padding: 8px 16px; border: 2px solid var(--border); border-radius: 30px; background: var(--bg-card); cursor: pointer; font-size: 13px; transition: all 0.2s; }
        .periodo-btn.ativo { background: #f59e0b; color: #1e293b; border-color: #f59e0b; font-weight: 600; }
        .info-periodo-stats { display: flex; gap: 15px; margin-top: 15px; padding: 10px; background: rgba(56, 189, 248, 0.1); border-radius: 12px; flex-wrap: wrap; }
        .loading-stats { text-align: center; padding: 40px; color: var(--text-secondary); }
        .error-stats { background: rgba(239, 68, 68, 0.1); border: 2px solid #ef4444; padding: 15px; border-radius: var(--radius); text-align: center; color: #fca5a5; }
        .footer-stats { margin-top: 40px; margin-bottom: 20px; text-align: center; }
        .btn-footer { background: #64748b; border: none; padding: 10px 25px; border-radius: 30px; color: white; font-weight: 600; cursor: pointer; margin: 5px; }
        .stats-note { font-size: 11px; color: #f59e0b; margin-top: 10px; text-align: center; }
        @media (max-width: 768px) { .stats-cards-grid { grid-template-columns: 1fr; } .lottery-grid-stats { grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); } }
    </style>
</head>
<body>
    <div class="header">
        <div class="header-content">
            <div class="header-logo"><img src="BrasãoRoa Imagem.png" onerror="this.style.display='none'" alt="Logo"></div>
            <div class="header-text">
                <h1>🧠 Loterias V.6.1 <span class="version-badge">ESTATÍSTICAS</span></h1>
                <p class="header-subtitle">Análise completa de números, duplas, tríades e times</p>
            </div>
            <div class="header-logo"><img src="BrasãoRoa Imagem.png" onerror="this.style.display='none'" alt="Logo"></div>
        </div>
    </div>

    <div class="stats-container">
        <div class="lottery-grid-stats" id="lotteryGridStats"></div>
        
        <div class="card">
            <h4>📅 Período (Baseado em data real)</h4>
            <div class="periodo-filtros" id="periodoFiltros">
                <button class="periodo-btn ativo" data-periodo="all">Todos</button>
                <button class="periodo-btn" data-periodo="1">1 Ano</button>
                <button class="periodo-btn" data-periodo="3">3 Anos</button>
                <button class="periodo-btn" data-periodo="5">5 Anos</button>
                <button class="periodo-btn" data-periodo="7">7 Anos</button>
                <button class="periodo-btn" data-periodo="9">9 Anos</button>
            </div>
            <div id="periodoInfo"></div>
        </div>
        
        <div id="estatisticasContent"><div class="loading-stats">📊 Carregando estatísticas...</div></div>
        
        <div class="footer-stats">
            <button class="btn-footer" onclick="window.location.href='index.html'">← Voltar ao Sistema</button>
            <div style="margin-top: 15px; font-size: 11px; color: var(--text-secondary);">© 2025 Loterias IA</div>
        </div>
    </div>

    <script>
        // ============================================
        // CONFIGURAÇÕES
        // ============================================
        const firebaseConfig = {
            apiKey: "AIzaSyCA_FoID7Ch8LkcwK5TbQSK23lU7BxQMuE",
            authDomain: "loteriasia.firebaseapp.com",
            projectId: "loteriasia",
            storageBucket: "loteriasia.firebasestorage.app",
            messagingSenderId: "124650527048",
            appId: "1:124650527048:web:bc335922cb9e1586c3fb7d"
        };
        
        // Inicializar Firebase
        if (!firebase.apps || firebase.apps.length === 0) {
            firebase.initializeApp(firebaseConfig);
        }
        
        const supabaseUrl = 'https://fuiaikymhsjdgdhojjhq.supabase.co';
        const supabaseKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZ1aWFpa3ltaHNqZGdkaG9qamhxIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzgwODI1NTEsImV4cCI6MjA5MzY1ODU1MX0.X9Qa1eJ6ut-QdKEZdjX2Ttm2STgJqOkEdNyohDpH3bk';
        window.supabaseClient = supabase.createClient(supabaseUrl, supabaseKey);
        
        let isUserPro = false;
        let loteriaAtualStats = 'megasena';
        let periodoSelecionadoStats = 'all';
        let dadosAtuaisStats = [];
        let dadosExtrasStats = [];
        
        const LOTERIAS_STATS = {
            megasena: { nome: 'Mega-Sena', icone: '💰', numerosCSV: 6, maxNumero: 60, incluirZero: false },
            quina: { nome: 'Quina', icone: '🎯', numerosCSV: 5, maxNumero: 80, incluirZero: false },
            lotofacil: { nome: 'Lotofácil', icone: '🍀', numerosCSV: 15, maxNumero: 25, incluirZero: false },
            lotomania: { nome: 'Lotomania', icone: '🎪', numerosCSV: 20, maxNumero: 99, incluirZero: true, observacao: 'CSV contém 20 números sorteados' },
            duplasena: { nome: 'Dupla Sena', icone: '🎲', numerosCSV: 6, maxNumero: 50, incluirZero: false },
            timemania: { nome: 'Timemania', icone: '⚽', numerosCSV: 7, maxNumero: 80, incluirZero: false, temTime: true },
            milionaria: { nome: '+Milionária', icone: '💎', numerosCSV: 6, maxNumero: 50, incluirZero: false },
            loteca: { nome: 'Loteca', icone: '⚽', numerosCSV: 14, maxNumero: 3, incluirZero: false },
            diadesorte: { nome: 'Dia de Sorte', icone: '📅', numerosCSV: 7, maxNumero: 31, incluirZero: false },
            supersete: { nome: 'Super Sete', icone: '🌟', numerosCSV: 7, maxNumero: 9, incluirZero: true }
        };
        
        const cacheDadosStats = {};
        
        // ============================================
        // VERIFICAR USUÁRIO PRO
        // ============================================
        firebase.auth().onAuthStateChanged(async (user) => {
            if (user) {
                try {
                    const { data } = await window.supabaseClient
                        .from('usuarios')
                        .select('is_pro')
                        .eq('uid', user.uid)
                        .single();
                    isUserPro = data?.is_pro || false;
                    console.log('📊 Estatísticas - Usuário PRO:', isUserPro);
                } catch(e) { 
                    isUserPro = false;
                    console.log('📊 Estatísticas - Usuário não encontrado');
                }
            } else {
                isUserPro = false;
                console.log('📊 Estatísticas - Nenhum usuário logado');
            }
            await carregarDadosLoteria();
        });
        
        // ============================================
        // FUNÇÕES DE FORMATAÇÃO
        // ============================================
        function formatarNumero(numero, incluirZero) {
            if (!isUserPro) return '<span class="numero-pro" title="🔒 Disponível no Plano PRO">⭐⭐ PRO ⭐⭐</span>';
            if (numero === 0 && incluirZero) return '00';
            return String(numero).padStart(2, '0');
        }
        
        function formatarDupla(dupla, incluirZero) {
            if (!isUserPro) return '(⭐⭐, ⭐⭐)';
            return `(${formatarNumero(dupla[0], incluirZero)}, ${formatarNumero(dupla[1], incluirZero)})`;
        }
        
        function formatarTripla(tripla, incluirZero) {
            if (!isUserPro) return '(⭐⭐, ⭐⭐, ⭐⭐)';
            return `(${formatarNumero(tripla[0], incluirZero)}, ${formatarNumero(tripla[1], incluirZero)}, ${formatarNumero(tripla[2], incluirZero)})`;
        }
        
        // ============================================
        // FUNÇÕES DE DATA
        // ============================================
        function getDataCortePorAnos(anos) {
            const dataAtual = new Date();
            return new Date(dataAtual.getFullYear() - anos, dataAtual.getMonth(), dataAtual.getDate());
        }
        
        // ============================================
        // CARREGAR CSV
        // ============================================
        async function carregarCSV(loteria) {
            const config = LOTERIAS_STATS[loteria];
            if (!config) return { dados: [], extras: [] };
            if (cacheDadosStats[loteria]) return cacheDadosStats[loteria];
            
            try {
                const response = await fetch(`csv/${loteria}.csv`);
                if (!response.ok) return { dados: [], extras: [] };
                
                const texto = await response.text();
                const linhas = texto.split('\n').filter(l => l.trim() && !l.startsWith('Data'));
                if (linhas.length < 2) return { dados: [], extras: [] };
                
                const sep = linhas[0]?.includes(';') ? ';' : ',';
                const dados = [];
                const extras = [];
                
                for (const linha of linhas) {
                    if (!linha.trim()) continue;
                    let colunas = linha.split(sep);
                    while (colunas.length > 0 && (colunas[colunas.length-1].trim() === '')) colunas.pop();
                    if (colunas.length < 2) continue;
                    
                    let data = null, dataIndex = -1;
                    for (let j = 0; j < colunas.length; j++) {
                        const v = colunas[j].trim();
                        if (/^\d{2}\/\d{2}\/\d{4}$/.test(v)) { 
                            data = v; 
                            dataIndex = j; 
                            break; 
                        }
                        if (/^\d{4}-\d{2}-\d{2}$/.test(v)) { 
                            const [a,m,d] = v.split('-'); 
                            data = `${d}/${m}/${a}`; 
                            dataIndex = j; 
                            break; 
                        }
                    }
                    if (!data) continue;
                    
                    const numeros = [];
                    let timeCoracao = null;
                    
                    for (let j = dataIndex+1; j < colunas.length; j++) {
                        let valor = colunas[j]?.trim();
                        if (!valor) continue;
                        
                        if (loteria === 'timemania' && isNaN(parseInt(valor))) {
                            timeCoracao = valor;
                            continue;
                        }
                        
                        let num = parseInt(valor);
                        if (isNaN(num)) continue;
                        if (num >= 0 && num <= config.maxNumero) numeros.push(num);
                    }
                    
                    if (numeros.length >= config.numerosCSV) {
                        dados.push({ 
                            numeros: numeros.slice(0, config.numerosCSV).sort((a,b)=>a-b), 
                            data: data 
                        });
                        if (loteria === 'timemania' && timeCoracao) extras.push(timeCoracao);
                        else extras.push(null);
                    }
                }
                
                const resultado = { dados, extras };
                cacheDadosStats[loteria] = resultado;
                return resultado;
            } catch(e) { 
                console.error('Erro ao carregar CSV:', e);
                return { dados: [], extras: [] }; 
            }
        }
        
        // ============================================
        // FILTRO POR PERÍODO
        // ============================================
        function filtrarPorPeriodo(dados, extras, periodo) {
            if (periodo === 'all') return { dados, extras };
            
            const anos = parseInt(periodo);
            const dataCorte = getDataCortePorAnos(anos);
            const dadosFiltrados = [];
            const extrasFiltrados = [];
            
            for (let i = 0; i < dados.length; i++) {
                const item = dados[i];
                if (!item.data) {
                    dadosFiltrados.push(item);
                    extrasFiltrados.push(extras[i]);
                    continue;
                }
                const partes = item.data.split('/');
                if (partes.length !== 3) {
                    dadosFiltrados.push(item);
                    extrasFiltrados.push(extras[i]);
                    continue;
                }
                const dataConcurso = new Date(parseInt(partes[2]), parseInt(partes[1])-1, parseInt(partes[0]));
                if (dataConcurso >= dataCorte) {
                    dadosFiltrados.push(item);
                    extrasFiltrados.push(extras[i]);
                }
            }
            return { dados: dadosFiltrados, extras: extrasFiltrados };
        }
        
        // ============================================
        // CÁLCULOS ESTATÍSTICOS
        // ============================================
        function calcularFrequencia(dados, maxNumero, incluirZero) {
            const limite = maxNumero + (incluirZero ? 1 : 0);
            const freq = new Array(limite).fill(0);
            dados.forEach(item => {
                item.numeros.forEach(n => { 
                    if (n >= 0 && n < limite) freq[n]++; 
                });
            });
            
            const resultados = [];
            for (let i = incluirZero ? 0 : 1; i < limite; i++) {
                resultados.push({ numero: i, quantidade: freq[i] });
            }
            resultados.sort((a,b) => b.quantidade - a.quantidade);
            return resultados;
        }
        
        function calcularDuplas(dados) {
            const duplas = new Map();
            dados.forEach(item => {
                const nums = item.numeros;
                for (let i = 0; i < nums.length; i++) {
                    for (let j = i+1; j < nums.length; j++) {
                        const key = `${Math.min(nums[i], nums[j])},${Math.max(nums[i], nums[j])}`;
                        duplas.set(key, (duplas.get(key) || 0) + 1);
                    }
                }
            });
            return Array.from(duplas.entries())
                .map(([key, qtd]) => ({ dupla: key.split(',').map(Number), quantidade: qtd }))
                .sort((a,b) => b.quantidade - a.quantidade)
                .slice(0,20);
        }
        
        function calcularTriplas(dados) {
            const triplas = new Map();
            dados.forEach(item => {
                const nums = item.numeros;
                for (let i = 0; i < nums.length; i++) {
                    for (let j = i+1; j < nums.length; j++) {
                        for (let k = j+1; k < nums.length; k++) {
                            const ordenados = [nums[i], nums[j], nums[k]].sort((a,b)=>a-b);
                            const key = `${ordenados[0]},${ordenados[1]},${ordenados[2]}`;
                            triplas.set(key, (triplas.get(key) || 0) + 1);
                        }
                    }
                }
            });
            return Array.from(triplas.entries())
                .map(([key, qtd]) => ({ tripla: key.split(',').map(Number), quantidade: qtd }))
                .sort((a,b) => b.quantidade - a.quantidade)
                .slice(0,20);
        }
        
        function calcularTimes(extras) {
            const times = new Map();
            extras.forEach(t => { 
                if (t) times.set(t, (times.get(t) || 0) + 1); 
            });
            return Array.from(times.entries())
                .map(([time, qtd]) => ({ time, quantidade: qtd }))
                .sort((a,b) => b.quantidade - a.quantidade)
                .slice(0,20);
        }
        
        // ============================================
        // RENDERIZAR ESTATÍSTICAS
        // ============================================
        async function renderizarEstatisticas() {
            const container = document.getElementById('estatisticasContent');
            const config = LOTERIAS_STATS[loteriaAtualStats];
            
            if (!dadosAtuaisStats || dadosAtuaisStats.length === 0) {
                container.innerHTML = '<div class="error-stats">⚠️ Nenhum dado disponível. Verifique o CSV.</div>';
                return;
            }
            
            const filtrado = filtrarPorPeriodo(dadosAtuaisStats, dadosExtrasStats, periodoSelecionadoStats);
            if (filtrado.dados.length === 0) {
                container.innerHTML = '<div class="error-stats">⚠️ Nenhum dado para o período selecionado.</div>';
                return;
            }
            
            const frequencia = calcularFrequencia(filtrado.dados, config.maxNumero, config.incluirZero);
            const maisSorteados = frequencia.slice(0,20);
            const menosSorteados = [...frequencia].sort((a,b) => a.quantidade - b.quantidade).slice(0,20);
            const duplas = calcularDuplas(filtrado.dados);
            const triplas = calcularTriplas(filtrado.dados);
            
            let timesHtml = '';
            if (config.temTime && loteriaAtualStats === 'timemania') {
                const times = calcularTimes(filtrado.extras);
                timesHtml = `
                    <div class="stats-card">
                        <h4>⚽ TIMES MAIS SORTEADOS</h4>
                        <div class="stats-list">
                            ${times.map(t => `
                                <div class="stats-item">
                                    <span class="${isUserPro ? 'numero' : 'numero-pro'}">${isUserPro ? t.time : '⭐⭐ PRO ⭐⭐'}</span>
                                    <span class="quantidade">${t.quantidade} vez(es)</span>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                `;
            }
            
            const proWarning = !isUserPro ? `
                <div class="pro-overlay" style="background: rgba(245, 158, 11, 0.1); border: 1px solid #f59e0b; margin-bottom: 20px;">
                    <span class="pro-badge-stats">⭐ PLANO PRO ⭐</span>
                    <p style="margin-top: 10px; font-size: 13px;">Faça login com uma conta PRO para visualizar todos os números e estatísticas completas!</p>
                    <button onclick="window.location.href='index.html'" style="background: linear-gradient(135deg, #f59e0b, #eab308); border: none; padding: 8px 20px; border-radius: 30px; color: #1e293b; font-weight: 600; cursor: pointer; margin-top: 10px;">⭐ IR PARA O SISTEMA</button>
                </div>
            ` : '';
            
            const observacaoHtml = config.observacao ? `<div class="stats-note">ℹ️ ${config.observacao}</div>` : '';
            
            const html = `
                ${proWarning}
                ${observacaoHtml}
                <div class="stats-cards-grid">
                    <div class="stats-card">
                        <h4>🔢 MAIS SORTEADOS (Top 20)</h4>
                        <div class="stats-list">
                            ${maisSorteados.map(item => `
                                <div class="stats-item">
                                    <span class="${isUserPro ? 'numero' : 'numero-pro'}">${formatarNumero(item.numero, config.incluirZero)}</span>
                                    <span class="quantidade">${item.quantidade} vez(es)</span>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                    
                    <div class="stats-card">
                        <h4>🔢 MENOS SORTEADOS (Bottom 20)</h4>
                        <div class="stats-list">
                            ${menosSorteados.map(item => `
                                <div class="stats-item">
                                    <span class="${isUserPro ? 'numero' : 'numero-pro'}">${formatarNumero(item.numero, config.incluirZero)}</span>
                                    <span class="quantidade">${item.quantidade} vez(es)</span>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                    
                    <div class="stats-card">
                        <h4>👥 DUPLAS MAIS SORTEADAS</h4>
                        <div class="stats-list">
                            ${duplas.map(item => `
                                <div class="stats-item">
                                    <span class="${isUserPro ? 'numero' : 'numero-pro'}">${formatarDupla(item.dupla, config.incluirZero)}</span>
                                    <span class="quantidade">${item.quantidade} vez(es)</span>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                    
                    <div class="stats-card">
                        <h4>🔢 TRÍADES MAIS SORTEADAS</h4>
                        <div class="stats-list">
                            ${triplas.map(item => `
                                <div class="stats-item">
                                    <span class="${isUserPro ? 'numero' : 'numero-pro'}">${formatarTripla(item.tripla, config.incluirZero)}</span>
                                    <span class="quantidade">${item.quantidade} vez(es)</span>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                    ${timesHtml}
                </div>
                
                <div style="margin-top: 20px; padding: 15px; background: rgba(56, 189, 248, 0.1); border-radius: 12px; text-align: center;">
                    <div style="font-size: 13px; color: var(--text-secondary);">
                        📊 Baseado em <strong>${filtrado.dados.length}</strong> concursos | 
                        🎯 ${config.numerosCSV} números por concurso (sorteados)
                        ${config.temTime ? ' | ⚽ Inclui análise de times' : ''}
                    </div>
                </div>
            `;
            
            container.innerHTML = html;
        }
        
        // ============================================
        // ATUALIZAR PERÍODO
        // ============================================
        async function atualizarPeriodoInfo() {
            const filtrado = filtrarPorPeriodo(dadosAtuaisStats, dadosExtrasStats, periodoSelecionadoStats);
            const periodoTexto = periodoSelecionadoStats === 'all' 
                ? `Todos os concursos (${filtrado.dados.length} concursos)`
                : `${periodoSelecionadoStats} ano(s) (${filtrado.dados.length} concursos)`;
            
            let primeiraData = 'N/A', ultimaData = 'N/A';
            if (filtrado.dados.length > 0) {
                primeiraData = filtrado.dados[0]?.data || 'N/A';
                ultimaData = filtrado.dados[filtrado.dados.length-1]?.data || 'N/A';
            }
            
            document.getElementById('periodoInfo').innerHTML = `
                <p>📊 ${periodoTexto}</p>
                <div class="info-periodo-stats">
                    <div><strong>📅 DATA INÍCIO:</strong> ${primeiraData}</div>
                    <div><strong>📅 DATA FIM:</strong> ${ultimaData}</div>
                </div>
            `;
        }
        
        // ============================================
        // CARREGAR DADOS DA LOTERIA
        // ============================================
        async function carregarDadosLoteria() {
            const container = document.getElementById('estatisticasContent');
            container.innerHTML = '<div class="loading-stats">📊 Carregando dados...</div>';
            
            const resultado = await carregarCSV(loteriaAtualStats);
            dadosAtuaisStats = resultado.dados;
            dadosExtrasStats = resultado.extras;
            
            if (dadosAtuaisStats.length === 0) {
                const config = LOTERIAS_STATS[loteriaAtualStats];
                container.innerHTML = `<div class="error-stats">⚠️ Nenhum dado encontrado para ${config.nome}. Verifique o arquivo CSV.</div>`;
                return;
            }
            
            await atualizarPeriodoInfo();
            await renderizarEstatisticas();
        }
        
        // ============================================
        // SELECIONAR LOTERIA
        // ============================================
        async function selecionarLoteriaStats(loteria) {
            loteriaAtualStats = loteria;
            document.querySelectorAll('.lottery-card-stats').forEach(c => c.classList.remove('active'));
            document.getElementById(`card-stats-${loteria}`)?.classList.add('active');
            await carregarDadosLoteria();
        }
        
        // ============================================
        // CARREGAR GRID
        // ============================================
        function carregarGrid() {
            const grid = document.getElementById('lotteryGridStats');
            grid.innerHTML = Object.entries(LOTERIAS_STATS).map(([id, c]) => `
                <div class="lottery-card-stats ${id === 'megasena' ? 'active' : ''}" 
                     onclick="selecionarLoteriaStats('${id}')" 
                     id="card-stats-${id}">
                    <h3>${c.icone} ${c.nome}</h3>
                    <p class="rules">${c.numerosCSV} números • 1 a ${c.maxNumero}${c.temTime ? ' + Time' : ''}</p>
                </div>
            `).join('');
        }
        
        // ============================================
        // INICIALIZAÇÃO
        // ============================================
        function init() {
            carregarGrid();
            
            document.querySelectorAll('.periodo-btn').forEach(btn => {
                btn.addEventListener('click', async () => {
                    document.querySelectorAll('.periodo-btn').forEach(b => b.classList.remove('ativo'));
                    btn.classList.add('ativo');
                    periodoSelecionadoStats = btn.dataset.periodo;
                    await atualizarPeriodoInfo();
                    await renderizarEstatisticas();
                });
            });
            
            // Carregar dados iniciais
            carregarDadosLoteria();
        }
        
        // Exportar função para o window
        window.selecionarLoteriaStats = selecionarLoteriaStats;
        
        // Iniciar
        init();
    </script>
</body>
</html>
