{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "node",
        "strict": false,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowJs": true,
        "noEmit": true
    },
    "include": ["api/**/*.ts", "core/**/*.ts"],
    "exclude": ["node_modules", "public"]
}
